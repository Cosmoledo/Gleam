{
	"name": "game-lib",
	"version": "1.0.0",
	"description": "A TypeScript game development framework with canvas rendering, audio support, and utility functions",
	"main": "dist/index.js",
	"types": "index.d.ts",
	"scripts": {
		"build": "tspc",
		"watch": "tspc -w",
		"lint": "eslint src tests --ext .ts",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:browser": "vitest run --project browser",
		"test:watch": "vitest"
	},
	"keywords": [
		"game",
		"canvas",
		"typescript",
		"framework",
		"2d",
		"renderer"
	],
	"author": "GameLIB Team",
	"license": "MIT",
	"dependencies": {
		"bezier-easing": "^3.0.0"
	},
	"devDependencies": {
		"@types/node": "^20.19.41",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"@vitest/browser": "^4.1.7",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "^4.1.6",
		"happy-dom": "^20.9.0",
		"playwright": "^1.60.0",
		"ts-patch": "^4.0.1",
		"typescript": "^6.0.3",
		"typescript-transform-paths": "^4.0.0",
		"vitest": "^4.1.6",
		"vitest-canvas-mock": "^1.1.4"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/game-lib/game-lib.git"
	}
}
