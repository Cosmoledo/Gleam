{
	"name": "@cosmoledo/gleam",
	"version": "1.0.2",
	"description": "TypeScript framework for 2D canvas games in the browser — graphics, loop, effects, audio, math.",
	"homepage": "https://github.com/Cosmoledo/Gleam#readme",
	"bugs": {
		"url": "https://github.com/Cosmoledo/Gleam/issues"
	},
	"type": "module",
	"main": "dist/gleam.esm.js",
	"types": "dist/gleam.d.ts",
	"exports": {
		".": {
			"types": "./dist/gleam.d.ts",
			"import": "./dist/gleam.esm.js"
		}
	},
	"sideEffects": [
		"./src/prototypes/*",
		"./src/localization/Translator.ts",
		"./dist/gleam.esm.js",
		"./dist/gleam.js",
		"./dist/gleam.min.js"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node scripts/build.mjs",
		"docs": "node scripts/docs.mjs",
		"lint": "eslint src tests --ext .ts",
		"prepublishOnly": "bash scripts/verify.sh",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:browser": "vitest run --project browser"
	},
	"engines": {
		"node": ">=24"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"game",
		"canvas",
		"typescript",
		"framework",
		"2d",
		"renderer"
	],
	"author": "Cosmoledo",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.4",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"dts-bundle-generator": "^9.5.1",
		"esbuild": "^0.28.1",
		"happy-dom": "^20.10.6",
		"playwright": "^1.61.1",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"vitest-canvas-mock": "^1.1.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Cosmoledo/Gleam.git"
	}
}
